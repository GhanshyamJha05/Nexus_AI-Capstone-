# ============================================================
# Nexus AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Application ----
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-long-random-secret-key-at-least-64-chars
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Google Gemini ----
GEMINI_API_KEY=add your api key here
GEMINI_MODEL=gemini-2.5-pro

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nexus_ai
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_password_change_in_prod
DATABASE_URL=postgresql+asyncpg://nexus:nexus_password_change_in_prod@postgres:5432/nexus_ai

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ---- Celery ----
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- ChromaDB (Vector Store) ----
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION=nexus_knowledge

# ---- JWT ----
JWT_SECRET_KEY=change-this-jwt-secret-key-also-long-and-random
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Rate Limiting ----
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=Nexus AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# ---- Email (optional) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@nexus-ai.com
SMTP_PASSWORD=
SMTP_TLS=true

# ---- Sentry (optional) ----
SENTRY_DSN=

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
