# Vercel env template — copy to `.vercel.env` or use the CLI to set
#
# IMPORTANT: Do NOT commit real secrets. This file is a template only.

# ---- Server / Secret (set as Project Secret on Vercel) ----
DATABASE_URL=postgresql+asyncpg://nexus:CHANGE_ME@postgres:5432/nexus_ai
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
JWT_SECRET_KEY=change-this-to-a-very-long-random-secret
APP_SECRET_KEY=change-this-to-a-very-long-random-secret
GEMINI_API_KEY=add-your-gemini-api-key-here
SENTRY_DSN=
UPLOAD_DIR=

# ---- Optional host/port fallbacks (non-secret) ----
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION=nexus_knowledge

# ---- Frontend (public, safe to expose) ----
# These are visible in the browser; only set non-sensitive values.
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_WS_URL=wss://api.example.com
NEXT_PUBLIC_APP_NAME=Nexus%20AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# ---- Logging & rate limiting ----
LOG_LEVEL=INFO
LOG_FORMAT=json
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CLI examples — set secrets for Production:
# vercel env add DATABASE_URL production
# vercel env add REDIS_URL production
# vercel env add GEMINI_API_KEY production
# vercel env add JWT_SECRET_KEY production
# vercel env add NEXT_PUBLIC_API_URL production
